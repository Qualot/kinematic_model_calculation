<?xml version="1.0"?>
<robot name="right">
  <!-- common materials -->
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="gray">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>
  <material name="green">
    <color rgba="0 1 0 1"/>
  </material>
  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>


  <!-- Pelvis -->
  <link name="pelvis">
    <visual>
      <geometry>
        <box size="0.15 0.15 0.15"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <!-- Femur -->
  <link name="femur">
    <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <visual>
      <geometry>
        <!-- <box size="0.05 0.05 0.3"/> -->
        <cylinder length="0.3" radius="0.025"/>
      </geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <!-- Tibia -->
  <link name="tibia">
    <!-- <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual> -->
    <visual>
      <geometry>
        <!-- <box size="0.05 0.05 0.3"/> -->
        <cylinder length="0.3" radius="0.025"/>
      </geometry>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <!-- Foot -->
  <link name="foot">
    <visual>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black"/>
    </visual>
    <visual>
      <geometry>
        <box size="0.2 0.1 0.05"/>
      </geometry>
      <origin xyz="0.05 0 -0.025" rpy="0 0 0"/>
      <material name="gray"/>
    </visual>
  </link>

  <!-- Hip joint (ball joint approximation using 3 continuous joints) -->
  <!-- <joint name="hip_yaw" type="continuous">
    <parent link="pelvis"/>
    <child link="hip_yaw_link"/>
    <origin xyz="0 -0.075 -0.075" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.3" upper="1.3" effort="50" velocity="1.0"/>
  </joint>

  <link name="hip_yaw_link"/>

  <joint name="hip_roll" type="continuous">
    <parent link="hip_yaw_link"/>
    <child link="hip_roll_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.3" upper="0.0" effort="50" velocity="1.0"/>
  </joint>

  <link name="hip_roll_link"/>

  <joint name="hip_pitch" type="continuous">
    <parent link="hip_roll_link"/>
    <child link="femur"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.3" upper="1.3" effort="50" velocity="1.0"/>
  </joint> -->

  <joint name="hip_roll" type="continuous">
    <parent link="pelvis"/>
    <child link="hip_roll_link"/>
    <origin xyz="0 -0.075 -0.075" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.3" upper="1.3" effort="50" velocity="1.0"/>
  </joint>

  <link name="hip_roll_link"/>

  <joint name="hip_pitch" type="continuous">
    <parent link="hip_roll_link"/>
    <child link="hip_pitch_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.3" upper="0.0" effort="50" velocity="1.0"/>
  </joint>

  <link name="hip_pitch_link"/>

  <joint name="hip_yaw" type="continuous">
    <parent link="hip_pitch_link"/>
    <child link="femur"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.3" upper="1.3" effort="50" velocity="1.0"/>
  </joint>



  <!-- Knee joint -->
  <joint name="knee_joint" type="revolute">
    <parent link="femur"/>
    <child link="tibia"/>
    <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="2.6" effort="50" velocity="1.0"/>
  </joint>

  <!-- Ankle joint -->
  <joint name="ankle_joint" type="revolute">
    <parent link="tibia"/>
    <child link="foot"/>
    <origin xyz="0 0 -0.3" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.0" upper="1.0" effort="50" velocity="1.0"/>
  </joint>
</robot>
